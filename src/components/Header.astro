---
import NavLinks from "./NavLinks.astro";
---

<header>
	<div id="logo-titles">
		<div id="top-component">
			<div id="titles">
				<h1>Alberta Paleontological Society</h1>
				<h2>
					The Meeting Place for Amateur and Professional
					Paleontologists
				</h2>
			</div>
		</div>
		<div id="other-logos">
			<img
				src="/logos/aps-logo.gif"
				alt="Alberta Paleontological Society Logo"
				class="logo"
			/>
			<img
				src="/logos/CEGA_logo.png"
				alt="Canadian Energy Geoscience Association Logo"
				class="logo"
			/>
			<img
				src="/logos/MRU_logo1.png"
				alt="Mount Royal Univerity Logo"
				class="logo"
			/>
		</div>
		<nav id="main-menu">
			<NavLinks />
		</nav>
	</div>

	<!-- Main section for the mobile / hamburger menu -->
	<!-- Hidden input for the hamburger menu -->
	<input type="checkbox" id="hamburger-input" />
	<label for="hamburger-input" id="hamburger-menu">
		<div id="hamburger-header-components">
			<div id="hamburger-icon">
				<span class="hamburger-line line1"></span>
				<span class="hamburger-line line2"></span>
				<span class="hamburger-line line3"></span>
			</div>
			<h1 id="sidebar-h1">Alberta Paleontological Society</h1>
		</div>
		<nav id="sidebar-menu">
			<NavLinks />
		</nav>
	</label>
</header>

<style>
	/* Header should be sticky to the top of the screen */
	header {
		position: sticky;
		top: 0px;
		background-color: white;
		padding-bottom: 16px;
	}

	/* Making the hamburger menu pop in and out */
	#hamburger-input {
		visibility: hidden;
		display: none;
	}
	#sidebar-menu {
		position: fixed;
		top: 0%;
		left: -250px;
		transition: 0.3s;
		visibility: hidden;
		z-index: 5;
	}
	#hamburger-input:checked + #hamburger-menu #sidebar-menu {
		left: 0%;
		background-color: red;
		visibility: visible;
	}

	/* Making the hamburger icon animate, &c. */
	#hamburger-icon {
		position: sticky;
		width: 32px;
		height: 32px;
		/* padding: 4px; */
		z-index: 999;
		flex-shrink: 0;
	}
	#hamburger-icon .hamburger-line {
		display: block;
		height: 4px;
		border-radius: 10px;
		background-color: black;
		margin: 4px;
	}
	#hamburger-icon .line1 {
		transform-origin: 0% 0%;
		transition: transform 0.4s ease-in-out;
	}

	#hamburger-icon .line2 {
		transition: transform 0.2s ease-in-out;
	}

	#hamburger-icon .line3 {
		transform-origin: 0% 100%;
		transition: transform 0.4s ease-in-out;
	}

	#hamburger-input:checked #hamburger-menu {
		transform: translateX(0);
	}

	#hamburger-input:checked ~ #hamburger-menu .line1 {
		transform: rotate(45deg);
	}
	#hamburger-input:checked ~ #hamburger-menu .line2 {
		transform: scaleY(0);
	}
	#hamburger-input:checked ~ #hamburger-menu .line3 {
		transform: rotate(-45deg);
	}

	/* Main settings for the desktop header */

	header img.logo {
		padding: 0 4px;
		height: 100px;
	}

	header img.main {
		padding: 4px;
		width: 100%;
		max-width: 600px;
	}

	header #other-logos {
		display: flex;
		flex-direction: row;
		justify-content: space-evenly;
	}
	header #top-component {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
	}

	/* Initally hide most of the header (logos, &c. - just show them on the desktop site) */
	#logo-titles {
		display: none;
		visibility: hidden;
	}

	#hamburger-header-components {
		display: flex;
		flex-direction: row;
	}

	#sidebar-h1 {
		text-align: center;
		flex-grow: 1;
	}

	/* Making it responsive  - these styles should be applied for the desktop version*/
	@media screen and (min-width: 768px) {
		/* Show the main header on the desktop version */
		#logo-titles {
			display: block;
			visibility: visible;
		}

		/* Hide the hamurger menu */
		#hamburger-icon {
			visibility: hidden;
			display: none;
		}

		/* Making the header behave the way we want - change this later so that we can have a main part that doesn't move but a nav section that does*/
		header {
			margin-top: 12px;
			display: flex;
			flex-direction: row;
			justify-content: center;
			align-items: flex-start;
		}

		#sidebar-h1 {
			visibility: hidden;
			display: none;
		}

		#main-menu {
			display: flex;
			flex-direction: row;
			align-items: center;
			justify-content: center;
		}
		#main-menu :global(ul) {
			list-style: none;
			display: flex;
			flex-direction: row;
		}

		#main-menu :global(li) {
			padding: 8px 16px;
			display: block;
		}

		#main-menu :global(a) {
			text-decoration: none;
			transition: 0.3s;
		}

		#main-menu :global(a):hover {
			background-color: green;
		}
	}
</style>
